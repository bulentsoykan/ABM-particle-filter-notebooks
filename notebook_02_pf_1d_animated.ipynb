    "           title=f't = {t}',\n",
    "           xlabel='X', ylabel='Y' if t == snapshots[0] else '')\n",
    "    if t == snapshots[0]:\n",
    "        ax.legend(fontsize=9, loc='upper left')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('fig_02b_pf_snapshots.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()\n"
   ]
