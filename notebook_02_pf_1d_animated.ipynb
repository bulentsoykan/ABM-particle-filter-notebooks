    "    ax.axvline(x_true, color='#f9826c', lw=2.5, zorder=5, label='True state')\n",
    "\n",
    "axes[0].scatter(prior_x, prior_y + 0.5, s=80, color='#58a6ff', alpha=0.7, zorder=3)\n",
